# =============================================================================
# Signal API - Environment Configuration (Self-Hosting)
# =============================================================================
# This is the configuration for the open-source Signal training API.
# For billing/credits/payments, see the Frontier Backend service.

# -----------------------------------------------------------------------------
# Supabase Configuration (Database)
# -----------------------------------------------------------------------------
# Signal uses Row Level Security (RLS) for database access control
# Uses ANON key with RLS policies instead of service role for security
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# SECURITY NOTE: We use the anon key (not service role) to implement 
# least-privilege access. RLS policies automatically enforce user isolation.
# See supabase/SETUP.md for migration instructions.

# -----------------------------------------------------------------------------
# Modal Configuration (GPU Infrastructure)
# -----------------------------------------------------------------------------
# Get these from modal.com after running `modal setup`
MODAL_TOKEN_ID=your-modal-token-id
MODAL_TOKEN_SECRET=your-modal-token-secret

# -----------------------------------------------------------------------------
# Model Access (Optional)
# -----------------------------------------------------------------------------
# HuggingFace token for accessing gated models (Llama, etc.)
HF_TOKEN=your-huggingface-token

# WandB token for experiment tracking (optional)
WANDB_API_KEY=your-wandb-key

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
ENABLE_RATE_LIMITING=true
MAX_REQUEST_SIZE_MB=20
MAX_CONCURRENT_RUNS_PER_USER=5

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
ENABLE_AUDIT_LOGGING=true

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
ENVIRONMENT=development